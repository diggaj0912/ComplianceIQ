{
  "name": "compliance-agent-unified",
  "version": "2.0.0",
  "description": "ComplianceIQ — AI-Powered GST Compliance Assistant",
  "private": true,
  "scripts": {
    "install:frontend": "cd frontend && pnpm install",
    "install:backend": "cd backend && python3 -m pip install --user --break-system-packages -r requirements.txt || python3 -m pip install --user -r requirements.txt",
    "start:backend": "cd backend && python3 -m uvicorn server:app --host 0.0.0.0 --port 8000 --reload",
    "start:frontend": "cd frontend && pnpm run dev",
    "dev": "cd frontend && pnpm run dev",
    "dev:frontend": "cd frontend && pnpm run dev",
    "dev:backend": "cd backend && python3 -m uvicorn server:app --host 0.0.0.0 --port 8000 --reload",
    "dev:full": "concurrently -k -p \"[{name}]\" -n \"backend,frontend\" -c \"blue.bold,green.bold\" \"pnpm run dev:backend\" \"pnpm run dev:frontend\"",
    "build:frontend": "cd frontend && pnpm run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    },
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild"
    ]
  },
  "dependencies": {
    "axios": "^1.18.1",
    "lucide-react": "^0.487.0",
    "react": "18.3.1",
    "react-router": "7.13.0",
    "recharts": "^3.9.0"
  }
}
